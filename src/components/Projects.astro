---

<SectionContainer id="projects" title="Projects" iconName="mdi:xml">
  {
    projects.map((project) => (
      <article class="project-card flex flex-col max-w-[480px] mx-auto lg:max-w-full lg:flex-row items-center shadow-xl rounded-lg mb-10 overflow-hidden">
        <div
          class={
            project.imageSrc
              ? "lg:flex-1 flex flex-col justify-between p-4 leading-normal lg:order-2"
              : "w-full flex flex-col justify-between p-4 leading-normal"
          }
        >
          <h3 class="flex items-center mb-1 text-2xl font-semibold">
            {project.title}
          </h3>
          <time class="block mb-2 text-sm leading-none">{project.date}</time>
          <p class="mb-2">{project.desc}</p>
          <div class="flex flex-col mb-4">
            {project.links.map((link) => (
              <Link text={link.text} href={link.url} target="_blank" />
            ))}
          </div>
          <div class="flex flex-wrap gap-3">
            {project.icons.map((icon) => (
              <Skill iconName={icon.iconName} skillName={icon.skillName} />
            ))}
          </div>
        </div>
        {project.imageSrc && (
          <div class="lg:flex-1 w-full lg:w-1/2 flex justify-center overflow-hidden">
            <Image
              src={project.imageSrc}
              alt={project.imageAlt}
              width={480}
              height={400}
              class="object-cover h-[420px] w-full transition-all duration-300 hover:scale-125 lg:hover:translate-x-12 lg:hover:translate-y-10"
            />
          </div>
        )}
      </article>
    ))
  }
</SectionContainer>
