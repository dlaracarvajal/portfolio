---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
// Supports weights 100-700 - Title Font
import "@fontsource-variable/josefin-sans";
// Body Font
import "@fontsource/fira-sans/300.css";
import "@fontsource/fira-sans/700.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C989FFG34D"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-C989FFG34D");
    </script>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Diego Lara Carvajal - Full-Stack Developer portfolio focused on production web platforms, internal tools, performance, automation, and MVP applications."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="py-4 px-6 max-w-7xl mx-auto">
    <Header />
    <slot />
    <Footer />
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
      defer></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
      defer></script>
    <script is:inline>
      window.addEventListener("load", () => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          return;
        }

        if (!window.gsap || !window.ScrollTrigger) {
          return;
        }

        const { gsap, ScrollTrigger } = window;

        gsap.registerPlugin(ScrollTrigger);

        const introTimeline = gsap.timeline({
          defaults: {
            ease: "power3.out",
          },
        });

        introTimeline
          .from("header", {
            autoAlpha: 0,
            y: -18,
            duration: 0.55,
          })
          .from(
            ".navBarLinks, header .socialIcons, header button",
            {
              autoAlpha: 0,
              y: -8,
              duration: 0.35,
              stagger: 0.06,
            },
            "-=0.35",
          )
          .from(
            "main h1, .hero-name",
            {
              autoAlpha: 0,
              y: 24,
              duration: 0.5,
            },
            "-=0.15",
          )
          .from(
            "main h1 + p, main .hero-description, main .hero-subtitle",
            {
              autoAlpha: 0,
              y: 18,
              duration: 0.5,
            },
            "-=0.35",
          )
          .from(
            ".hero-photo",
            {
              autoAlpha: 0,
              scale: 0.96,
              y: 16,
              duration: 0.6,
            },
            "-=0.5",
          )
          .from(
            "main .button, main .socialIcons",
            {
              autoAlpha: 0,
              y: 14,
              duration: 0.45,
              stagger: 0.06,
            },
            "-=0.3",
          );

        function animateSection(sectionSelector, itemSelector) {
          const section = document.querySelector(sectionSelector);

          if (!section) {
            return;
          }

          const sectionHeader = section.querySelector(":scope > div");
          const items = [
            sectionHeader,
            ...section.querySelectorAll(itemSelector),
          ].filter(Boolean);

          if (!items.length) {
            return;
          }

          gsap.from(items, {
            autoAlpha: 0,
            y: 28,
            duration: 0.55,
            ease: "power3.out",
            stagger: 0.1,
            scrollTrigger: {
              trigger: section,
              start: "top 78%",
              once: true,
            },
          });
        }

        animateSection("#about", "article");

        const experienceSection = document.querySelector("#experience");

        if (experienceSection) {
          const experienceHeader =
            experienceSection.querySelector(":scope > div");
          const experienceLine =
            experienceSection.querySelector(".experience-line");
          const experienceItems = experienceSection.querySelectorAll("li");

          gsap.set(experienceLine, {
            scaleY: 0,
          });

          gsap.set(experienceItems, {
            autoAlpha: 0,
            y: 24,
          });

          const experienceTimeline = gsap.timeline({
            scrollTrigger: {
              trigger: experienceSection,
              start: "top 78%",
              once: true,
            },
          });

          experienceTimeline
            .from(experienceHeader, {
              autoAlpha: 0,
              y: 24,
              duration: 0.45,
              ease: "power3.out",
            })
            .to(
              experienceLine,
              {
                scaleY: 1,
                duration: 0.75,
                ease: "power2.out",
              },
              "-=0.15",
            )
            .to(
              experienceItems,
              {
                autoAlpha: 1,
                y: 0,
                duration: 0.45,
                ease: "power3.out",
                stagger: 0.1,
              },
              "-=0.55",
            );
        }

        animateSection("#projects", ".project-card");
        animateSection("#education", "article, li");
        animateSection("#contact", "form");

        ScrollTrigger.refresh();
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    background-color: #f1f5f9;
    scroll-behavior: smooth;
  }
  html.dark {
    background-color: #1e293b;
    color: #fff;
  }

  body {
    font-family: "Fira Sans", sans-serif;
    font-size: 18px;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: "Josefin Sans Variable", sans-serif;
  }

  .loader {
    border: 5px solid #f3f3f3;
    border-top: 5px solid #3498db;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    animation: spin 2s linear infinite;
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .dark #experience h3,
  .dark #projects h3,
  .dark #education h3,
  .dark #about strong,
  .dark #about b,
  .dark .hero-name,
  .dark .navBarLinks:hover {
    color: #dfb457fe;
  }

  .navBarLinks,
  .socialIcons {
    transition:
      transform 0.2s ease-in-out,
      color 0.2s ease-in-out;
  }

  .navBarLinks:hover,
  .socialIcons:hover {
    transform: scale(1.2);
  }

  .button {
    transition:
      transform 0.2s ease-in-out,
      color 0.2s ease-in-out;
  }

  .button:hover {
    transform: scale(1.1);
  }

  .footerLinks:hover {
    text-decoration-line: underline;
  }

  .linkComponent {
    color: #2563eb;
  }

  .dark .linkComponent {
    color: #93c5fd;
  }
</style>
